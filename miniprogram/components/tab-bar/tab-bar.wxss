/* ============================================
   底部导航栏 — 固定于底部，适配安全区域
   ============================================ */

.tab-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: var(--tab-bar-height, 100rpx);
  padding-bottom: env(safe-area-inset-bottom);
  background: var(--color-card, #FFFFFF);
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-around;
  border-top: 1rpx solid var(--color-border, #EEEEEE);
  z-index: 900;
  box-shadow: 0 -2rpx 8rpx rgba(0, 0, 0, 0.04);
}

/* ====== 单个 Tab 项 ====== */
.tab-bar__item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 100%;
  padding: 8rpx 0;
  transition: transform 0.2s;
}

.tab-bar__item:active {
  transform: scale(0.92);
}

/* ====== 图标 ====== */
.tab-bar__icon {
  font-size: 40rpx;
  line-height: 1;
  margin-bottom: 4rpx;
  transition: transform 0.2s, opacity 0.2s;
}

/* 非选中态：降低透明度模拟灰色 */
.tab-bar__item:not(.tab-bar__item--active) .tab-bar__icon {
  opacity: 0.45;
  filter: grayscale(100%);
}

/* 选中态：橙色 */
.tab-bar__item--active .tab-bar__icon {
  opacity: 1;
  filter: none;
  transform: scale(1.08);
}

/* ====== 文字 ====== */
.tab-bar__text {
  font-size: 20rpx;
  color: var(--color-text-secondary, #999999);
  font-weight: 400;
  line-height: 1;
  transition: color 0.2s, font-weight 0.2s;
}

.tab-bar__item--active .tab-bar__text {
  color: var(--color-primary, #FF6B35);
  font-weight: 600;
}
