<view class="ring-chart-wrapper" style="width: {{size}}rpx; height: {{size}}rpx;">
  <!-- Canvas 2D 绘制环形 -->
  <canvas
    type="2d"
    id="ringCanvas"
    class="ring-canvas"
    style="width: {{size}}rpx; height: {{size}}rpx;"
  ></canvas>

  <!-- CSS 降级文本层（Canvas 未就绪时展示） -->
  <view class="ring-text-fallback" wx:if="{{!label && !subLabel}}">
    <text class="ring-percent-text">{{percent}}%</text>
  </view>
</view>
