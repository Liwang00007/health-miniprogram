/* pages/statistics/statistics.wxss */
.page {
  padding: 16rpx 32rpx 120rpx;
  height: 100%;
}

/* 加载骨架屏 */
.loading-block {
  padding-top: 16rpx;
}
.skeleton-card {
  padding: 32rpx;
  margin-bottom: 16rpx;
}
.skeleton-line {
  height: 28rpx;
  background: linear-gradient(90deg, #f0f0f0 25%, #e0e0e0 50%, #f0f0f0 75%);
  border-radius: 8rpx;
  margin-bottom: 16rpx;
}
.skeleton-line-short {
  width: 50%;
}

/* 概览卡片网格 */
.overview-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 12rpx;
  margin-bottom: 24rpx;
}

.stat-card {
  text-align: center;
  padding: 32rpx 16rpx;
}

.stat-val {
  font-size: 40rpx;
  font-weight: 800;
  color: var(--color-primary);
  display: block;
}

.stat-u {
  font-size: 22rpx;
  font-weight: 400;
  color: #999;
}

.stat-label {
  font-size: 22rpx;
  color: #999;
  display: block;
  margin-top: 6rpx;
}

/* 区域分组 */
.section {
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: 700;
  display: block;
  margin-bottom: 16rpx;
}

/* 肌群分布条 */
.dist-item {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 14rpx;
}

.dist-name {
  font-size: 24rpx;
  width: 70rpx;
  flex-shrink: 0;
}

.dist-bar-bg {
  flex: 1;
  height: 16rpx;
  background: #f0f0f0;
  border-radius: 8rpx;
  overflow: hidden;
}

.dist-bar {
  height: 100%;
  background: linear-gradient(90deg, #FF6B35, #FF8F5E);
  border-radius: 8rpx;
  transition: width 0.5s ease;
}

.dist-count {
  font-size: 22rpx;
  color: #999;
  width: 60rpx;
  text-align: right;
  flex-shrink: 0;
}

.dist-empty {
  text-align: center;
  padding: 32rpx 0;
  font-size: 24rpx;
  color: #bbb;
}

/* 热量概览 */
.calorie-overview {
  display: flex;
  justify-content: space-around;
  padding: 16rpx 0;
}

.calo-item {
  text-align: center;
}

.calo-note {
  display: block;
  text-align: center;
  font-size: 20rpx;
  color: #bbb;
  margin-top: 8rpx;
}

/* 蛋白质摄入 */
.protein-row {
  display: flex;
  align-items: baseline;
  gap: 16rpx;
  padding: 16rpx 0;
}

.protein-value {
  font-size: 44rpx;
  font-weight: 800;
  color: var(--color-primary);
}

.protein-label {
  font-size: 24rpx;
  color: #999;
}
