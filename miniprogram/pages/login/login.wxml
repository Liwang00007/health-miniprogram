<!-- pages/login/login.wxml -->
<navigation-bar title="FitPlan" back="{{false}}" color="white" background="#2D2D2D"></navigation-bar>

<view class="page">

  <view class="brand-area">
    <view class="logo-box">💪</view>
    <view class="app-name">FitPlan 健身助手</view>
    <view class="app-desc">智能训练与饮食管理，让每一次健身都看得见</view>

    <view class="feat-list">
      <view class="feat-row">
        <view class="feat-icon feat-orange">📊</view>
        <view class="feat-info">
          <view class="feat-title">科学记录</view>
          <view class="feat-desc">训练数据与饮食营养一键记录</view>
        </view>
      </view>
      <view class="feat-row">
        <view class="feat-icon feat-blue">🤖</view>
        <view class="feat-info">
          <view class="feat-title">AI 定制计划</view>
          <view class="feat-desc">个性化训练与饮食方案智能生成</view>
        </view>
      </view>
      <view class="feat-row">
        <view class="feat-icon feat-green">📈</view>
        <view class="feat-info">
          <view class="feat-title">数据可视化</view>
          <view class="feat-desc">训练周报与成长趋势一目了然</view>
        </view>
      </view>
    </view>
  </view>

  <view class="login-area">
    <view class="err-msg" wx:if="{{errorMsg}}">{{errorMsg}}</view>

    <!-- 微信登录按钮 — 用 view 代替 button，Skyline 下更稳定 -->
    <view class="wx-btn" bindtap="handleWechatLogin">
      💬  微信一键登录
    </view>

    <!-- 隐私协议 -->
    <view class="privacy-line" bindtap="toggleAgreement">
      <view class="cb {{agreedToPrivacy ? 'on' : ''}}">
        <text wx:if="{{agreedToPrivacy}}">✓</text>
      </view>
      <view class="privacy-txt">
        已阅读并同意
        <text class="link" bindtap="viewPrivacyPolicy">《隐私政策》</text>
        和
        <text class="link" bindtap="viewUserAgreement">《用户协议》</text>
      </view>
    </view>

    <view class="bonus-line">🎁 注册即送 <text class="hl">10 积分</text>，开启智能健身之旅</view>

    <view class="skip-line" bindtap="skipLogin">暂不登录，先看看 →</view>
  </view>

</view>
