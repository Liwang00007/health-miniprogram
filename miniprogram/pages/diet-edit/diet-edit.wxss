/* pages/diet-edit/diet-edit.wxss */

.page {
  padding: 16rpx 32rpx 160rpx;
}

/* ====== 表单通用 ====== */
.form-group {
  margin-bottom: 32rpx;
}

.form-label {
  font-size: 26rpx;
  font-weight: 600;
  color: #2D2D2D;
  display: block;
  margin-bottom: 12rpx;
}

.form-input {
  background: #fff;
  border-radius: var(--radius-md);
  padding: 20rpx 24rpx;
  font-size: 28rpx;
  border: 1rpx solid var(--color-border);
  width: 100%;
}

.form-error {
  font-size: 22rpx;
  color: var(--color-danger);
  margin-top: 8rpx;
  display: block;
}

.form-textarea {
  background: #fff;
  border-radius: var(--radius-md);
  padding: 20rpx 24rpx;
  font-size: 28rpx;
  width: 100%;
  min-height: 120rpx;
  border: 1rpx solid var(--color-border);
}

/* ====== 餐别芯片 ====== */
.chip-row {
  display: flex;
  gap: 12rpx;
}

.chip {
  flex: 1;
  text-align: center;
  padding: 16rpx;
  border-radius: var(--radius-md);
  font-size: 26rpx;
  background: #fff;
  color: #666;
  border: 1rpx solid var(--color-border);
}

.chip-active {
  background: #FFF5F0;
  border-color: var(--color-primary);
  color: var(--color-primary);
  font-weight: 600;
}

/* ====== 食物搜索 ====== */
.search-box {
  position: relative;
}

.search-input {
  background: #fff;
  border-radius: var(--radius-md);
  padding: 20rpx 24rpx;
  font-size: 28rpx;
  border: 1rpx solid var(--color-primary-light);
  width: 100%;
}

.searching-hint {
  position: absolute;
  right: 24rpx;
  top: 50%;
  transform: translateY(-50%);
  font-size: 22rpx;
  color: var(--color-text-gray);
}

/* 搜索结果面板 */
.search-results {
  background: #fff;
  border-radius: var(--radius-md);
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.12);
  margin-top: 8rpx;
  max-height: 400rpx;
  overflow-y: auto;
}

.search-item {
  padding: 20rpx 24rpx;
  border-bottom: 1rpx solid #f5f5f5;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.search-item:last-child {
  border-bottom: none;
}

.search-item-main {
  flex: 1;
  min-width: 0;
}

.search-item-name {
  font-size: 28rpx;
  font-weight: 500;
  color: #2D2D2D;
  display: block;
}

.search-item-category {
  font-size: 20rpx;
  color: var(--color-text-light);
  background: var(--color-bg);
  padding: 2rpx 12rpx;
  border-radius: 8rpx;
  display: inline-block;
  margin-top: 4rpx;
}

.search-item-nutrition {
  text-align: right;
  flex-shrink: 0;
  margin-left: 16rpx;
}

.search-item-cal {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--color-primary);
  display: block;
}

.search-item-macro {
  font-size: 20rpx;
  color: var(--color-text-gray);
  display: block;
  margin-top: 2rpx;
}

.no-result {
  padding: 24rpx;
  text-align: center;
  font-size: 24rpx;
  color: var(--color-text-gray);
  background: #fff;
  border-radius: var(--radius-md);
  margin-top: 8rpx;
}

/* ====== 已选食物列表 ====== */
.foods-section {
  margin-bottom: 32rpx;
}

.food-item {
  margin-bottom: 12rpx;
  padding: 20rpx 24rpx;
}

.food-item-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.food-item-info {
  flex: 1;
  min-width: 0;
}

.food-item-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #2D2D2D;
  display: block;
}

.food-item-meta {
  font-size: 22rpx;
  color: var(--color-text-gray);
  margin-top: 2rpx;
}

.food-item-delete {
  font-size: 32rpx;
  padding: 8rpx;
  flex-shrink: 0;
}

/* 份量调节 */
.food-item-bottom {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.weight-label {
  font-size: 24rpx;
  color: var(--color-text-gray);
  flex-shrink: 0;
}

.weight-control {
  display: flex;
  align-items: center;
  gap: 0;
  background: var(--color-bg);
  border-radius: var(--radius-sm);
  overflow: hidden;
}

.weight-btn {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: 600;
  color: var(--color-primary);
  background: #fff;
}

.weight-btn:active {
  background: #FFF5F0;
}

.weight-input {
  width: 100rpx;
  height: 56rpx;
  text-align: center;
  font-size: 28rpx;
  font-weight: 600;
  background: #fff;
  color: #2D2D2D;
}

.weight-unit {
  font-size: 24rpx;
  color: var(--color-text-gray);
  flex-shrink: 0;
}

.food-actual {
  margin-left: auto;
}

.food-actual-cal {
  font-size: 26rpx;
  font-weight: 700;
  color: var(--color-primary);
}

/* ====== 营养预览 ====== */
.nutrition-preview {
  margin-bottom: 32rpx;
  padding: 24rpx;
}

.preview-title {
  font-size: 26rpx;
  font-weight: 600;
  display: block;
  margin-bottom: 20rpx;
  color: #2D2D2D;
}

.preview-grid {
  display: flex;
}

.preview-item {
  flex: 1;
  text-align: center;
}

.preview-val {
  font-size: 34rpx;
  font-weight: 800;
  display: block;
}

.preview-val-cal {
  color: var(--color-warning);
}

.preview-val-protein {
  color: var(--color-primary);
}

.preview-val-carbs {
  color: #4A90D9;
}

.preview-val-fat {
  color: #E8A838;
}

.preview-label {
  font-size: 20rpx;
  color: var(--color-text-gray);
  margin-top: 4rpx;
}

/* ====== 保存按钮 ====== */
.save-btn {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  text-align: center;
  padding: 28rpx;
  font-size: 32rpx;
  font-weight: 600;
  z-index: 100;
  border-radius: 0;
}
