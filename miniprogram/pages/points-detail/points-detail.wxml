<!-- pages/points-detail/points-detail.wxml — 积分明细页 -->
<navigation-bar title="积分明细" color="white" background="#2D2D2D"></navigation-bar>

<scroll-view scroll-y class="page page--no-tab" bindscrolltolower="loadMore">

  <!-- ====== 积分余额卡片 ====== -->
  <view class="balance-card">
    <view class="balance-header">
      <text class="balance-star">⭐</text>
      <text class="balance-label">当前积分</text>
    </view>
    <text class="balance-num">{{userPoints}}</text>
    <view class="balance-divider"></view>
    <view class="balance-info flex-row gap-lg">
      <view class="bal-info-item">
        <text class="bal-info-value">{{streakDays}}</text>
        <text class="bal-info-label">连续签到</text>
      </view>
      <view class="bal-info-item">
        <text class="bal-info-value">{{total}}</text>
        <text class="bal-info-label">积分记录</text>
      </view>
    </view>
  </view>

  <!-- ====== 签到按钮 ====== -->
  <view class="checkin-section">
    <view
      class="checkin-btn {{checkedToday ? 'checkin-btn--done' : ''}} {{checkingIn ? 'checkin-btn--loading' : ''}}"
      bindtap="handleCheckIn"
    >
      <text wx:if="{{checkedToday}}" class="checkin-icon">✅</text>
      <text wx:else class="checkin-icon">📅</text>
      <text class="checkin-text">
        {{checkingIn ? '签到中…' : (checkedToday ? '今日已签到' : '每日签到 +1')}}
      </text>
    </view>
  </view>

  <!-- ====== 积分规则卡片 ====== -->
  <view class="card rules-card">
    <view class="card-title">📋 积分规则</view>
    <view class="rule-item">
      <text class="rule-label">新用户注册</text>
      <text class="rule-value text-success">+10 积分</text>
    </view>
    <view class="rule-item">
      <text class="rule-label">每日签到</text>
      <text class="rule-value text-success">+1 积分</text>
    </view>
    <view class="rule-item">
      <text class="rule-label">连续签到 7 天</text>
      <text class="rule-value text-success">+3 额外积分</text>
    </view>
    <view class="rule-item">
      <text class="rule-label">连续签到 30 天</text>
      <text class="rule-value text-success">+10 额外积分</text>
    </view>
    <view class="rule-item">
      <text class="rule-label">完成训练目标</text>
      <text class="rule-value text-success">+2 积分</text>
    </view>
    <view class="divider"></view>
    <view class="rule-item">
      <text class="rule-label">AI 生成训练计划</text>
      <text class="rule-value text-danger">-3 积分</text>
    </view>
    <view class="rule-item">
      <text class="rule-label">AI 生成饮食计划</text>
      <text class="rule-value text-danger">-2 积分</text>
    </view>
  </view>

  <!-- ====== 积分变动日志 ====== -->
  <view class="logs-section">
    <view class="card-title" style="margin-bottom: 0;">📜 积分记录</view>

    <!-- 加载中骨架屏 -->
    <view wx:if="{{loading && logs.length === 0}}">
      <view class="skeleton skeleton--card" wx:for="{{[1,2,3]}}" wx:key="index" style="height: 80rpx;"></view>
    </view>

    <!-- 空状态 -->
    <empty-state
      wx:elif="{{!loading && logs.length === 0}}"
      icon="📜"
      text="暂无积分记录"
      hint="签到或完成训练即可获得积分"
    ></empty-state>

    <!-- 日志列表 -->
    <view wx:else class="logs-list">
      <view wx:for="{{logs}}" wx:key="_id" class="log-item">
        <view class="log-left">
          <text class="log-desc">{{item.description}}</text>
          <text class="log-time">{{item.createdAt}}</text>
        </view>
        <text class="log-amount {{item.amount > 0 ? 'text-success' : 'text-danger'}}">
          {{item.amount > 0 ? '+' : ''}}{{item.amount}}
        </text>
      </view>

      <!-- 加载更多 -->
      <view wx:if="{{hasMore}}" class="load-more" bindtap="loadMore">
        <text class="text-sm text-secondary">{{loading ? '加载中…' : '加载更多'}}</text>
      </view>

      <view wx:elif="{{logs.length > 0}}" class="load-more">
        <text class="text-sm" style="color: var(--color-text-hint);">— 已加载全部 {{total}} 条记录 —</text>
      </view>
    </view>
  </view>

  <view style="height: 48rpx;"></view>
</scroll-view>
