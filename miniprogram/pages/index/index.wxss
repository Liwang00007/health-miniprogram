/* index.wxss — Skyline 纯 block + 简单 flex */

page {
  background: #F5F5F5;
}

.container {
  padding: 16rpx 32rpx 120rpx;
}

/* ====== 登录卡片 ====== */
.login-card {
  background: #2D2D2D;
  border-radius: 24rpx;
  padding: 64rpx 32rpx;
  text-align: center;
  margin-bottom: 16rpx;
}

.login-icon {
  font-size: 64rpx;
  margin-bottom: 16rpx;
}

.login-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: 8rpx;
}

.login-desc {
  font-size: 24rpx;
  color: rgba(255,255,255,0.7);
  margin-bottom: 32rpx;
}

.login-btn {
  background: #07C160;
  color: #fff;
  padding: 16rpx 64rpx;
  border-radius: 48rpx;
  font-size: 30rpx;
  font-weight: 600;
  display: inline-block;
}

.guest-link {
  text-align: center;
  padding: 24rpx;
  font-size: 24rpx;
  color: #999;
}

/* ====== 用户卡片 ====== */
.user-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  border: 1rpx solid #eee;
}

.user-row {
  display: flex;
  align-items: center;
}

.user-avatar {
  width: 88rpx;
  height: 88rpx;
  border-radius: 44rpx;
  background: #f0f0f0;
}

.user-center {
  flex: 1;
  margin-left: 20rpx;
}

.user-name {
  font-size: 30rpx;
  font-weight: 700;
  color: #2D2D2D;
  margin-bottom: 4rpx;
}

.user-motto {
  font-size: 22rpx;
  color: #999;
}

.points-box {
  background: #FFF5F0;
  border-radius: 16rpx;
  padding: 16rpx 24rpx;
  text-align: center;
}

.points-star {
  font-size: 28rpx;
}

.points-num {
  font-size: 36rpx;
  font-weight: 800;
  color: #FF6B35;
}

.points-tag {
  font-size: 20rpx;
  color: #999;
}

/* ====== 区块标题 ====== */
.block-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #2D2D2D;
  padding: 8rpx 0;
  margin-top: 28rpx;
  margin-bottom: 16rpx;
}

/* ====== 概览 ====== */
.overview-line {
  display: flex;
  margin-bottom: 16rpx;
}

.ov-item {
  flex: 1;
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  text-align: center;
  border: 1rpx solid #eee;
}

.ov-item:first-child {
  margin-right: 16rpx;
}

.ov-val {
  font-size: 40rpx;
  font-weight: 800;
  color: #2D2D2D;
  margin-bottom: 4rpx;
}

.ov-primary {
  color: #FF6B35;
}

.ov-unit {
  font-size: 22rpx;
  font-weight: 400;
  color: #999;
  margin-left: 4rpx;
}

.ov-label {
  font-size: 22rpx;
  color: #999;
}

/* ====== 快速入口 ====== */
.quick-line {
  display: flex;
}

.act-card {
  flex: 1;
  border-radius: 16rpx;
  padding: 24rpx 4rpx;
  text-align: center;
}

.act-card:not(:last-child) {
  margin-right: 12rpx;
}

.act-orange { background: #FFF5F0; }
.act-green  { background: #F0FFF5; }
.act-blue   { background: #F0F5FF; }
.act-purple { background: #F8F0FF; }

.act-icon {
  font-size: 40rpx;
  margin-bottom: 6rpx;
}

.act-name {
  font-size: 22rpx;
  color: #333;
  font-weight: 500;
}

/* ====== 空状态 ====== */
.empty-block {
  text-align: center;
  padding: 80rpx 32rpx;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 16rpx;
}

.empty-text {
  font-size: 26rpx;
  color: #999;
  margin-bottom: 8rpx;
}

.empty-hint {
  font-size: 22rpx;
  color: #ccc;
}
