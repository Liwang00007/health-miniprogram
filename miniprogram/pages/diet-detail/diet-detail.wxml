<!-- pages/diet-detail/diet-detail.wxml -->
<navigation-bar title="饮食详情" color="white" background="#2D2D2D"></navigation-bar>

<scroll-view scroll-y class="page page--no-tab" wx:if="{{!loading}}">

  <!-- 加载失败 / 记录不存在 -->
  <view wx:if="{{!record}}" class="empty-state">
    <view class="empty-state__icon">🍽️</view>
    <view class="empty-state__text">记录不存在或已删除</view>
    <view class="empty-state__hint">请返回重新选择</view>
  </view>

  <!-- 记录详情 -->
  <view wx:else class="detail-content">

    <!-- 记录头 -->
    <view class="card detail-header">
      <view class="flex-between">
        <view class="flex-row gap-sm">
          <text class="meal-icon">{{record.mealType === 'breakfast' ? '🌅' : record.mealType === 'lunch' ? '☀️' : record.mealType === 'dinner' ? '🌙' : '🍪'}}</text>
          <view>
            <text class="meal-type">{{mealLabels[record.mealType] || record.mealType}}</text>
            <text class="meal-date">{{record.date}}</text>
          </view>
        </view>
        <view class="calorie-badge">
          <text class="calorie-num">{{record.totalCalories || 0}}</text>
          <text class="calorie-unit">kcal</text>
        </view>
      </view>
    </view>

    <!-- 食物列表 -->
    <view class="section-title">🍽️ 食物明细</view>
    <view wx:for="{{record.foods}}" wx:key="name" class="card food-item">
      <view class="flex-between food-header">
        <view class="flex-row gap-sm">
          <text class="food-index">{{index + 1}}</text>
          <text class="food-name">{{item.name}}</text>
        </view>
        <text class="food-weight">{{item.weight}}g</text>
      </view>

      <!-- 营养素条 -->
      <view class="nutrition-bars">
        <view class="nutri-item">
          <text class="nutri-label">热量</text>
          <view class="nutri-bar-wrap">
            <view class="nutri-bar nutri-cal" style="width: {{item.calories > 0 ? Math.min(100, (item.calories * item.weight / 100) / (record.totalCalories || 1) * 100) : 0}}%;"></view>
          </view>
          <text class="nutri-val">{{item.calories * item.weight / 100}}<text class="nutri-unit">kcal</text></text>
        </view>
        <view class="nutri-item">
          <text class="nutri-label">蛋白质</text>
          <view class="nutri-bar-wrap">
            <view class="nutri-bar nutri-protein" style="width: {{item.protein > 0 ? Math.min(100, (item.protein * item.weight / 100) / (record.totalProtein || 1) * 100) : 0}}%;"></view>
          </view>
          <text class="nutri-val">{{(item.protein * item.weight / 100).toFixed(1)}}<text class="nutri-unit">g</text></text>
        </view>
        <view class="nutri-item">
          <text class="nutri-label">碳水</text>
          <view class="nutri-bar-wrap">
            <view class="nutri-bar nutri-carbs" style="width: {{item.carbs > 0 ? Math.min(100, (item.carbs * item.weight / 100) / (record.totalCarbs || 1) * 100) : 0}}%;"></view>
          </view>
          <text class="nutri-val">{{(item.carbs * item.weight / 100).toFixed(1)}}<text class="nutri-unit">g</text></text>
        </view>
        <view class="nutri-item">
          <text class="nutri-label">脂肪</text>
          <view class="nutri-bar-wrap">
            <view class="nutri-bar nutri-fat" style="width: {{item.fat > 0 ? Math.min(100, (item.fat * item.weight / 100) / (record.totalFat || 1) * 100) : 0}}%;"></view>
          </view>
          <text class="nutri-val">{{(item.fat * item.weight / 100).toFixed(1)}}<text class="nutri-unit">g</text></text>
        </view>
      </view>
    </view>

    <!-- 营养汇总 -->
    <view class="card nutrition-summary">
      <text class="section-title" style="margin-top: 0;">📊 营养汇总</text>
      <view class="nutrition-grid">
        <view class="nutri-card nutri-cal-bg">
          <text class="nutri-card-val">{{record.totalCalories || 0}}</text>
          <text class="nutri-card-label">热量 (kcal)</text>
        </view>
        <view class="nutri-card nutri-protein-bg">
          <text class="nutri-card-val">{{record.totalProtein || 0}}g</text>
          <text class="nutri-card-label">蛋白质</text>
        </view>
        <view class="nutri-card nutri-carbs-bg">
          <text class="nutri-card-val">{{record.totalCarbs || 0}}g</text>
          <text class="nutri-card-label">碳水化合物</text>
        </view>
        <view class="nutri-card nutri-fat-bg">
          <text class="nutri-card-val">{{record.totalFat || 0}}g</text>
          <text class="nutri-card-label">脂肪</text>
        </view>
      </view>
    </view>

    <!-- 备注 -->
    <view wx:if="{{record.notes}}" class="card notes-card">
      <text class="notes-title">📝 备注</text>
      <text class="notes-content">{{record.notes}}</text>
    </view>

    <!-- 操作按钮 -->
    <view class="action-row flex-row gap-sm">
      <view class="edit-btn flex-1" bindtap="editRecord">
        <text>✏️ 编辑</text>
      </view>
      <view class="delete-btn flex-1" bindtap="deleteRecord">
        <text wx:if="{{!deleting}}">🗑️ 删除</text>
        <text wx:else>删除中…</text>
      </view>
    </view>

    <!-- 底部留白 -->
    <view style="height: 80rpx;"></view>

  </view>
</scroll-view>

<!-- 加载中 -->
<view wx:if="{{loading}}" class="empty-state" style="padding-top: 200rpx;">
  <view class="skeleton skeleton--card" style="margin: 0 24rpx;"></view>
  <view class="skeleton skeleton--card" style="margin: 16rpx 24rpx;"></view>
  <view class="skeleton skeleton--card" style="margin: 16rpx 24rpx;"></view>
</view>
