/* pages/settings/settings.wxss */

/* ====== 分组 ====== */
.settings-group {
  margin: var(--spacing-lg) var(--spacing-lg) 0;
}

.group-title {
  font-size: var(--font-sm);
  color: var(--color-text-secondary);
  padding: var(--spacing-xs) 0 var(--spacing-sm);
  display: block;
  font-weight: 500;
}

/* ====== 设置项 ====== */
.setting-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 0;
}

.setting-left {
  display: flex;
  align-items: center;
  gap: var(--spacing-md);
}

.setting-icon {
  font-size: 36rpx;
  width: 48rpx;
  text-align: center;
}

.setting-label {
  font-size: var(--font-base);
  color: var(--color-text);
}

.setting-arrow {
  font-size: 36rpx;
  color: var(--color-text-hint);
}

.setting-value {
  font-size: var(--font-sm);
  color: var(--color-text-secondary);
}
