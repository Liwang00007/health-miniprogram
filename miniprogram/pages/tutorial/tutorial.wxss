/* pages/tutorial/tutorial.wxss — 教程 Tab */

/* ====== 导航栏右侧 ====== */
.nav-right {
  display: flex;
  align-items: center;
  padding-right: 16rpx;
}

.nav-btn {
  font-size: 36rpx;
  padding: 8rpx;
}

/* ====== 搜索栏 ====== */
.search-bar {
  margin: 16rpx 24rpx;
}

.search-input-wrap {
  display: flex;
  align-items: center;
  background: var(--color-card);
  border-radius: 48rpx;
  padding: 12rpx 20rpx;
  box-shadow: var(--shadow-card);
}

.search-icon {
  font-size: 28rpx;
  margin-right: 8rpx;
  opacity: 0.5;
}

.search-input {
  flex: 1;
  height: 48rpx;
  font-size: var(--font-base);
  color: var(--color-text);
}

/* ====== 分类横条 ====== */
.category-scroll {
  white-space: nowrap;
  margin-bottom: 8rpx;
}

.category-list {
  display: inline-flex;
  padding: 0 24rpx;
  gap: var(--spacing-sm);
}

.category-tag {
  display: inline-block;
  padding: 10rpx 24rpx;
  font-size: var(--font-sm);
  color: var(--color-text-secondary);
  background: var(--color-card);
  border-radius: 48rpx;
  border: 1rpx solid var(--color-border);
  transition: all 0.25s;
}

.category-tag--active {
  background: var(--color-primary);
  color: #fff;
  border-color: var(--color-primary);
}

/* ====== 教程列表 ====== */
.tutorial-item {
  margin: 0 24rpx 8rpx;
  padding: 20rpx var(--spacing-lg);
}

.tutorial-cover {
  width: 120rpx;
  height: 90rpx;
  border-radius: var(--radius-sm);
  overflow: hidden;
  background: var(--color-bg);
  flex-shrink: 0;
}

.tutorial-img {
  width: 100%;
  height: 100%;
}

.tutorial-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
}

.tutorial-name {
  font-size: var(--font-base);
  font-weight: 600;
  color: var(--color-text);
  margin-bottom: 4rpx;
}

.tutorial-desc {
  margin-top: 4rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.fav-btn {
  font-size: 36rpx;
  flex-shrink: 0;
  padding: 8rpx;
  transition: transform 0.2s;
}

.fav-btn:active {
  transform: scale(1.2);
}
