<!-- pages/tutorial/tutorial.wxml — 教程 Tab -->
<navigation-bar title="教程库" back="{{false}}" color="white" background="#2D2D2D">
  <view slot="right" class="nav-right">
    <view class="nav-btn" bindtap="onMyFavorites">⭐</view>
  </view>
</navigation-bar>

<view class="page">

  <!-- ====== 搜索栏 ====== -->
  <view class="search-bar">
    <view class="search-input-wrap">
      <view class="search-icon">🔍</view>
      <input
        class="search-input"
        placeholder="搜索动作、教程…"
        value="{{searchKeyword}}"
        bindinput="onSearchInput"
        bindconfirm="onSearchConfirm"
      />
    </view>
  </view>

  <!-- ====== 分类筛选横条 ====== -->
  <scroll-view class="category-scroll" scroll-x enable-flex>
    <view class="category-list">
      <view
        wx:for="{{categories}}"
        wx:key="key"
        class="category-tag {{activeCategory === item.key ? 'category-tag--active' : ''}}"
        data-key="{{item.key}}"
        bindtap="onCategoryTap"
      >{{item.name}}</view>
    </view>
  </scroll-view>

  <!-- ====== 教程列表 ====== -->
  <view wx:if="{{tutorials.length === 0}}" class="empty-state">
    <view class="empty-state__icon">📖</view>
    <view class="empty-state__text">暂无教程内容</view>
    <view class="empty-state__hint">教程内容即将上线，敬请期待</view>
  </view>

  <block wx:for="{{tutorials}}" wx:key="id">
    <view class="card tutorial-item" data-id="{{item.id}}" bindtap="onTutorialTap">
      <view class="flex-row gap-sm">
        <!-- 封面缩略图 -->
        <view class="tutorial-cover">
          <image wx:if="{{item.coverUrl}}" src="{{item.coverUrl}}" mode="aspectFill" class="tutorial-img"/>
          <view wx:else class="tutorial-placeholder">📹</view>
        </view>
        <view class="flex-1">
          <view class="tutorial-name">{{item.title}}</view>
          <view class="text-sm text-secondary">{{item.category}} · {{item.duration || '3min'}}</view>
          <view class="tutorial-desc text-sm text-secondary">{{item.desc}}</view>
        </view>
        <view class="fav-btn" data-id="{{item.id}}" catchtap="onToggleFavorite">
          {{favoriteIds[item.id] ? '❤️' : '🤍'}}
        </view>
      </view>
    </view>
  </block>

  <view style="height: 40rpx;"></view>

</view>

<tab-bar current="tutorial"></tab-bar>
