/** app.wxss — FitPlan 全局样式 **/

/* ============================================
   设计 Token（需求文档 §3.1）
   ============================================ */
page {
  --color-primary: #FF6B35;
  --color-primary-light: #FFF5F0;
  --color-primary-dark: #E55A2B;
  --color-bg: #F5F5F5;
  --color-card: #FFFFFF;
  --color-text: #2D2D2D;
  --color-text-secondary: #999999;
  --color-text-hint: #CCCCCC;
  --color-success: #07C160;
  --color-danger: #FF4757;
  --color-warning: #FFA502;
  --color-border: #EEEEEE;
  --radius-sm: 8rpx;
  --radius-md: 16rpx;
  --radius-card: 20rpx;
  --radius-lg: 24rpx;
  --radius-round: 100rpx;
  --shadow-card: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
  --shadow-popup: 0 -4rpx 20rpx rgba(0, 0, 0, 0.1);
  --font-xs: 20rpx;
  --font-sm: 22rpx;
  --font-base: 26rpx;
  --font-md: 28rpx;
  --font-lg: 32rpx;
  --font-xl: 36rpx;
  --font-xxl: 44rpx;
  --spacing-xs: 8rpx;
  --spacing-sm: 12rpx;
  --spacing-md: 16rpx;
  --spacing-lg: 24rpx;
  --spacing-xl: 32rpx;
  --spacing-xxl: 48rpx;
  --tab-bar-height: 100rpx;

  background: var(--color-bg);
  color: var(--color-text);
  font-size: var(--font-base);
  font-family: -apple-system, BlinkMacSystemFont, "Helvetica Neue", "PingFang SC", "Microsoft YaHei", sans-serif;
  line-height: 1.5;
  box-sizing: border-box;
}

/* ============================================
   页面基础布局
   ============================================ */
.page {
  min-height: 100vh;
  padding-bottom: calc(var(--tab-bar-height) + env(safe-area-inset-bottom) + 24rpx);
  box-sizing: border-box;
}

.page--no-tab {
  min-height: 100vh;
  padding-bottom: 24rpx;
  box-sizing: border-box;
}

/* ============================================
   卡片样式
   ============================================ */
.card {
  background: var(--color-card);
  border-radius: var(--radius-card);
  padding: var(--spacing-lg);
  margin-bottom: var(--spacing-sm);
  box-shadow: var(--shadow-card);
  border: 1rpx solid var(--color-border);
}

.card--flat {
  box-shadow: none;
  border: none;
}

/* ============================================
   按钮样式
   ============================================ */
.btn {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 88rpx;
  border-radius: var(--radius-md);
  font-size: var(--font-md);
  font-weight: 600;
  transition: transform 0.2s, opacity 0.2s;
  box-sizing: border-box;
}

.btn:active {
  transform: scale(0.96);
  opacity: 0.85;
}

.btn-primary {
  background: var(--color-primary);
  color: #FFFFFF;
}

.btn-primary:active {
  background: var(--color-primary-dark);
}

.btn-ghost {
  background: transparent;
  color: var(--color-primary);
  border: 2rpx solid var(--color-primary);
}

.btn-success {
  background: var(--color-success);
  color: #FFFFFF;
}

.btn-sm {
  height: 64rpx;
  padding: 0 var(--spacing-lg);
  font-size: var(--font-sm);
  border-radius: var(--radius-sm);
}

/* ============================================
   区块标题
   ============================================ */
.section-title {
  font-size: var(--font-md);
  font-weight: 700;
  color: var(--color-text);
  padding: var(--spacing-xs) 0;
  margin-top: var(--spacing-lg);
  margin-bottom: var(--spacing-md);
}

/* ============================================
   空状态
   ============================================ */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 32rpx;
  text-align: center;
}

.empty-state__icon {
  font-size: 80rpx;
  margin-bottom: var(--spacing-md);
  opacity: 0.6;
}

.empty-state__text {
  font-size: var(--font-base);
  color: var(--color-text-secondary);
  margin-bottom: var(--spacing-xs);
}

.empty-state__hint {
  font-size: var(--font-sm);
  color: var(--color-text-hint);
  margin-bottom: var(--spacing-lg);
}

.empty-state__action {
  margin-top: var(--spacing-md);
}

/* ============================================
   骨架屏
   ============================================ */
.skeleton {
  background: linear-gradient(90deg, #F0F0F0 25%, #E8E8E8 50%, #F0F0F0 75%);
  background-size: 200% 100%;
  animation: skeleton-loading 1.5s ease-in-out infinite;
  border-radius: var(--radius-sm);
}

.skeleton--text {
  height: 28rpx;
  width: 100%;
  margin-bottom: var(--spacing-sm);
}

.skeleton--title {
  height: 36rpx;
  width: 60%;
  margin-bottom: var(--spacing-md);
}

.skeleton--avatar {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
}

.skeleton--card {
  height: 160rpx;
  border-radius: var(--radius-card);
  margin-bottom: var(--spacing-sm);
}

@keyframes skeleton-loading {
  0%   { background-position: 200% 0; }
  100% { background-position: -200% 0; }
}

/* ============================================
   Toast 提示
   ============================================ */
.toast {
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  background: rgba(0, 0, 0, 0.75);
  color: #fff;
  font-size: var(--font-base);
  padding: 16rpx 32rpx;
  border-radius: var(--radius-sm);
  z-index: 9999;
  animation: toast-fade 0.3s ease;
}

@keyframes toast-fade {
  from { opacity: 0; transform: translate(-50%, -50%) scale(0.8); }
  to   { opacity: 1; transform: translate(-50%, -50%) scale(1); }
}

/* ============================================
   Flex 辅助
   ============================================ */
.flex-row {
  display: flex;
  flex-direction: row;
  align-items: center;
}

.flex-col {
  display: flex;
  flex-direction: column;
}

.flex-1 {
  flex: 1;
}

.flex-center {
  display: flex;
  align-items: center;
  justify-content: center;
}

.flex-between {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.flex-wrap {
  flex-wrap: wrap;
}

/* ============================================
   间距辅助
   ============================================ */
.gap-xs  { gap: var(--spacing-xs); }
.gap-sm  { gap: var(--spacing-sm); }
.gap-md  { gap: var(--spacing-md); }
.gap-lg  { gap: var(--spacing-lg); }

.mt-sm  { margin-top: var(--spacing-sm); }
.mt-md  { margin-top: var(--spacing-md); }
.mt-lg  { margin-top: var(--spacing-lg); }
.mb-sm  { margin-bottom: var(--spacing-sm); }
.mb-md  { margin-bottom: var(--spacing-md); }
.mb-lg  { margin-bottom: var(--spacing-lg); }

.p-md   { padding: var(--spacing-md); }
.p-lg   { padding: var(--spacing-lg); }
.px-md  { padding-left: var(--spacing-md); padding-right: var(--spacing-md); }
.px-lg  { padding-left: var(--spacing-lg); padding-right: var(--spacing-lg); }

/* ============================================
   文字辅助
   ============================================ */
.text-center { text-align: center; }
.text-left   { text-align: left; }
.text-right  { text-align: right; }

.text-xs  { font-size: var(--font-xs); }
.text-sm  { font-size: var(--font-sm); }
.text-md  { font-size: var(--font-md); }
.text-lg  { font-size: var(--font-lg); }
.text-xl  { font-size: var(--font-xl); }

.text-secondary { color: var(--color-text-secondary); }
.text-primary   { color: var(--color-primary); }
.text-danger    { color: var(--color-danger); }
.text-success   { color: var(--color-success); }

.font-bold    { font-weight: 700; }
.font-semibold { font-weight: 600; }

/* ============================================
   分隔线
   ============================================ */
.divider {
  height: 1rpx;
  background: var(--color-border);
  margin: var(--spacing-md) 0;
}

/* ============================================
   安全区域
   ============================================ */
.safe-area-bottom {
  padding-bottom: env(safe-area-inset-bottom);
}

.safe-area-top {
  padding-top: env(safe-area-inset-top);
}
